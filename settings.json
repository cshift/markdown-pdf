  // "markdown-pdf.footerTemplate": "<div style=\"font-size: 8px; width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 8px 1cm 0 1cm; border-top: 1px solid #e0e0e0; color: #666; font-family: 'Noto Sans KR', sans-serif;\"><span>© 2026 Written by EdwardArchive(contributor in starrocks) | Confidential</span><span>Page <span class='pageNumber'></span> of <span class='totalPages'></span></span></div>",

  // 여백 설정 (헤더/푸터 공간 최적화)
  "markdown-pdf.margin.top": "25mm",
  "markdown-pdf.margin.bottom": "22mm",
  "markdown-pdf.margin.right": "18mm",
  "markdown-pdf.margin.left": "18mm",
  
  // 코드 하이라이팅 (github-dark도 좋은 대안)
  "markdown-pdf.highlight": true,
  "markdown-pdf.highlightStyle": "atom-one-dark.css" ,
  
  // 페이지 설정
  "markdown-pdf.format": "A4",
  "markdown-pdf.orientation": "portrait",
  "markdown-pdf.printBackground": true,
  
  // 기본 스타일 포함 여부 (커스텀 CSS와 함께 사용)
  "markdown-pdf.includeDefaultStyles": false,
  
  // 커스텀 CSS 경로 (프로젝트 루트 기준)
  // "markdown-pdf.styles": [
  //   "tamplate\\cutsom-style_ALPS.css"
  // ],
  "markdown-pdf.stylesRelativePathFile": true,
  "markdown-pdf.mermaidServer": "https://unpkg.com/mermaid@10.3.1/dist/mermaid.min.js",
  
  // 이모지 지원
  "markdown-pdf.emoji": true,
  
  // 줄바꿈 설정
  "markdown-pdf.breaks": false
}